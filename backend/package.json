{
  "name": "unified-social-inbox-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build": "node -e \"console.log('Backend uses native ESM and does not require a separate build step.')\"",
    "prisma:generate": "prisma generate --schema ../database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../database/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema ../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "cookie": "^1.0.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "googleapis": "^137.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.56.0",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.16.1"
  }
}
